    "The quick brown fox jumps over the lazy dog.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The quick brown fox jumps over the lazy dog."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Franz jagt im komplett verwahrlosten Taxi quer durch Bayern."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Portez ce vieux whisky au juge blond qui fume."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El veloz murciélago hindú comía feliz cardillo y kiwi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quel vituperabile xenofobo zozza ha giubba e fez."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "敏捷的棕色狐狸跳过懒狗。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "素早い茶色の狐は怠惰な犬を飛び越える。"
          }
        }
      }
    },
