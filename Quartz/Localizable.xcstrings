    "Choose a folder on your device.\\nQuartz will use it as your note vault.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a folder on your device.\nQuartz will use it as your note vault."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle einen Ordner auf deinem Gerät.\nQuartz wird ihn als Notiz-Vault verwenden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez un dossier sur votre appareil.\nQuartz l'utilisera comme coffre de notes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una carpeta en tu dispositivo.\nQuartz la usará como bóveda de notas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli una cartella sul tuo dispositivo.\nQuartz la userà come archivio note."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择设备上的一个文件夹。\nQuartz 将用它作为笔记保管库。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス上のフォルダを選択してください。\nQuartzがノート保管庫として使用します。"
          }
        }
      }
    },
