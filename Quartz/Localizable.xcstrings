    "Unable to access the selected folder. Please try again.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to access the selected folder. Please try again."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriff auf den ausgewählten Ordner nicht möglich. Bitte versuche es erneut."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'accéder au dossier sélectionné. Veuillez réessayer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede acceder a la carpeta seleccionada. Inténtalo de nuevo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile accedere alla cartella selezionata. Riprova."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法访问所选文件夹。请重试。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したフォルダにアクセスできません。もう一度お試しください。"
          }
        }
      }
    },
    "Could not open the selected folder. Please try again.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not open the selected folder. Please try again."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der ausgewählte Ordner konnte nicht geöffnet werden. Bitte versuche es erneut."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'ouvrir le dossier sélectionné. Veuillez réessayer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo abrir la carpeta seleccionada. Inténtalo de nuevo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile aprire la cartella selezionata. Riprova."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法打开所选文件夹。请重试。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したフォルダを開けませんでした。もう一度お試しください。"
          }
        }
      }
    },
    "Search index could not be built. Search may be incomplete.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search index could not be built. Search may be incomplete."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Suchindex konnte nicht erstellt werden. Die Suche ist möglicherweise unvollständig."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'index de recherche n'a pas pu être créé. La recherche peut être incomplète."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo crear el índice de búsqueda. La búsqueda puede ser incompleta."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile creare l'indice di ricerca. La ricerca potrebbe essere incompleta."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法构建搜索索引。搜索结果可能不完整。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検索インデックスを構築できませんでした。検索結果が不完全な場合があります。"
          }
        }
      }
    },
