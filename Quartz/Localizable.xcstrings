    "Choose a note from the sidebar to start editing.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a note from the sidebar to start editing."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle eine Notiz in der Seitenleiste, um zu bearbeiten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une note dans la barre latérale pour commencer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una nota de la barra lateral para empezar a editar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli una nota dalla barra laterale per iniziare a modificare."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从侧边栏选择一个笔记开始编辑。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サイドバーからノートを選択して編集を開始してください。"
          }
        }
      }
    },
