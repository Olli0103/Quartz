    "Open a vault folder to start\\ntaking beautiful notes.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open a vault folder to start\ntaking beautiful notes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffne einen Vault-Ordner, um mit\nschönen Notizen zu beginnen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez un dossier coffre pour\ncommencer à prendre de belles notes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre una carpeta de bóveda para\nempezar a tomar notas hermosas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri una cartella archivio per iniziare\na creare bellissime note."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开保管库文件夹\n开始撰写精美笔记。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保管庫フォルダを開いて\n美しいノートを始めましょう。"
          }
        }
      }
    },
